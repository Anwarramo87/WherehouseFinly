{
  "name": "factory",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "dev:webpack": "next dev",
    "dev:local": "node scripts/switch-backend.js local && npm run dev",
    "dev:remote": "node scripts/switch-backend.js remote && npm run dev",
    "backend:local": "node scripts/switch-backend.js local",
    "backend:remote": "node scripts/switch-backend.js remote",
    "backend:status": "node scripts/switch-backend.js --status",
    "build": "next build",
    "analyze": "cross-env PORT=4010 next experimental-analyze",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write \"{app,components,hooks,lib,stores,types}/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"{app,components,hooks,lib,stores,types}/**/*.{ts,tsx}\"",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "npm run lint && npm run typecheck && npm run build",
    "audit:deps": "npm audit --audit-level=high"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/query-sync-storage-persister": "^5.101.1",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-query-devtools": "^5.99.0",
    "@tanstack/react-query-persist-client": "^5.101.1",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.2",
    "axios": "^1.14.0",
    "clsx": "^2.1.1",
    "enhanced-resolve": "^5.21.3",
    "lucide-react": "^1.6.0",
    "next": "^16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.75.0",
    "react-hot-toast": "^2.6.0",
    "react-to-print": "^3.3.0",
    "read-excel-file": "^8.0.3",
    "recharts": "^3.8.1",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "xlsx": "0.18.5",
    "zod": "^4.4.3",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "eslint-plugin-sonarjs": "^4.1.0",
    "fast-check": "^4.8.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.5.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "ws": "^8.20.1"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Edge versions",
    "last 2 Safari versions",
    "not dead",
    "not ie 11"
  ]
}
